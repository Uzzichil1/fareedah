# =============================================================================
# TinyKloset — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Every variable the app reads is listed here. Phase 1 only needs the database
# and auth-secret values; the rest are wired in later phases but documented now.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# Supabase Dashboard -> Project Settings -> Database -> Connection string.
#   DATABASE_URL : "Transaction" pooler (PgBouncer, port 6543). Used at runtime.
#   DIRECT_URL   : "Session"/direct connection (port 5432). Used by migrations.
# Keep the ?pgbouncer=true&connection_limit=1 params on the pooled URL.
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# Auth.js (NextAuth) — Phase 2
# AUTH_SECRET: generate with `npx auth secret` (or `openssl rand -base64 32`).
# AUTH_URL: the app's base URL (http://localhost:3000 in dev).
# -----------------------------------------------------------------------------
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Google SSO — Google Cloud Console -> Credentials -> OAuth client ID (Web).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple SSO — wired in code but DEFERRED until Apple Developer credentials exist.
# Requires a paid Apple Developer account (Service ID, Team ID, Key ID, .p8 key).
APPLE_CLIENT_ID=""          # Services ID, e.g. com.tinykloset.web
APPLE_CLIENT_SECRET=""      # Generated JWT (built from Team ID + Key ID + private key below); read directly by auth.ts
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""        # Contents of the AuthKey_XXXX.p8 file (keep newlines escaped)

# -----------------------------------------------------------------------------
# Stripe Connect — marketplace payments / escrow / commission (Phase 4)
# Stripe Dashboard -> Developers -> API keys. Use TEST keys in development.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=""                      # sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""     # pk_test_...  (safe to expose client-side)
STRIPE_WEBHOOK_SECRET=""                  # whsec_... (from `stripe listen` or dashboard)
STRIPE_CONNECT_CLIENT_ID=""               # ca_... for Connect onboarding (optional w/ Express)

# -----------------------------------------------------------------------------
# Shippo — prepaid shipping labels (Phase 4)
# Shippo Dashboard -> Settings -> API. Use a TEST token in development.
# -----------------------------------------------------------------------------
SHIPPO_API_KEY=""           # shippo_test_...

# -----------------------------------------------------------------------------
# Cloudinary — image upload, resizing, optimization, CDN (Phase 3)
# Cloudinary Dashboard -> Product Environment Credentials.
# Create an unsigned upload preset for direct browser uploads.
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_PRESET=""                 # used for unsigned client uploads
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""        # public cloud name for client-side widget

# -----------------------------------------------------------------------------
# Platform config defaults (overridable in the admin panel — Phase 4)
# -----------------------------------------------------------------------------
PLATFORM_COMMISSION_PERCENT="18"            # default commission %, spec range 15–20
PAYOUT_AUTO_RELEASE_DAYS="3"                # passive payout window after delivery
